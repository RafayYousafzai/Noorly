{
  "expo": {
    "name": "Noorly",
    "slug": "noorly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/global-logo.png",
    "scheme": "noorly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/global-logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#646362",
        "foregroundImage": "./assets/images/global-logo.png",
        "backgroundImage": "./assets/images/global-logo.png",
        "monochromeImage": "./assets/images/global-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rafayyousafzai.noorly"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/global-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "barStyle": "light",
          "visibility": "visible"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "enforceContrast": true,
        "barStyle": "light",
        "visibility": "visible"
      },
      "eas": {
        "projectId": "ffdf61d1-2c94-4efe-b882-6106d2eb38bb"
      }
    }
  }
}
